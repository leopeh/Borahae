*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{

    font-family:'Poppins',sans-serif;

    color:white;

    overflow-x:hidden;

    background:linear-gradient(160deg,#0a0518,#1d1038,#35185f,#54268d);

